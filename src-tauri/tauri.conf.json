{
  "productName": "Schedule I Mod Manager",
  "version": "0.7.2",
  "identifier": "com.s1devenvmanager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "decorations": false,
        "title": "Schedule I Mod Manager",
        "width": 1270,
        "height": 884
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/SIMM/cache/mod-icons/**"
        ]
      }
    }
  },
"bundle": {
    "active": true,
    "targets": "all",
    "publisher": "LockWire Labs",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
